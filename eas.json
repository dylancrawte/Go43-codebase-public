{
  "cli": {
    "version": ">= 16.4.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "development"
    },
    "preview": {
      "channel": "preview",
      "ios": {
        "resourceClass": "m-medium"
      },
      
      "distribution": "internal",
      "env": {
        "EXPO_EAS_BUILD_SKIP_CACHE": "1",
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium"
      },
      
      "distribution": "store",
      "env": {
        "EXPO_EAS_BUILD_SKIP_CACHE": "1",
        "APP_VARIANT": "prod"
      }
    }
  },
  "submit": {
    "production": {},
    "dev": {}
  }
}
