# Copy to .env and fill in your own values (never commit .env)

# Backend API (required for auth, bookings, campaigns)
EXPO_PUBLIC_BACKEND_URL=https://your-api.example.com

# TikTok OAuth (client secret must stay on your server — do not ship in mobile builds)
EXPO_PUBLIC_TIKTOK_CLIENT_KEY=your_tiktok_client_key
EXPO_PUBLIC_REDIRECT_URI=https://your-domain.example.com/api/auth/oauth/callback

# Cloudinary unsigned upload (public cloud name + preset only)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Expo / EAS (optional — push notifications & EAS builds)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-uuid

# iOS universal links — comma-separated, e.g. applinks:yourdomain.com
# EXPO_PUBLIC_IOS_ASSOCIATED_DOMAINS=applinks:yourdomain.com,applinks:www.yourdomain.com

# App links & support (optional)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy-policy
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com

# Build variant: dev | preview | prod
APP_VARIANT=dev
